# LLM API Keys (provide at least one)
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here

# LLM Model Configuration
# Supported: gpt-4o, gpt-4o-mini, gpt-4-turbo, gpt-4, gpt-3.5-turbo,
#            gpt-5, o3, o3-mini, o4-mini,
#            claude-3-opus, claude-3-sonnet, claude-3-haiku, claude-3.5-sonnet
# Or any OpenAI-compatible model name.
LLM_MODEL=gpt-4o

# Optional: override the API base URL for OpenAI-compatible providers
# (Azure OpenAI, Ollama, LiteLLM proxy, OpenRouter, etc.)
# OPENAI_BASE_URL=https://your-proxy.example.com/v1

# Server Configuration
NODE_ENV=development
PORT=3001
MAX_FILE_SIZE=104857600

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
